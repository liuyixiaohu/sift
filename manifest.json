{
  "manifest_version": 3,
  "name": "JobLens",
  "version": "1.2",
  "description": "Clean up LinkedIn: filter jobs, hide feed ads & distractions, mute people & keywords, and declutter profile pages.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/feed/*", "https://www.linkedin.com/"],
      "css": ["feed.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.linkedin.com/feed/*", "https://www.linkedin.com/"],
      "js": ["feed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "css": ["profile.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["profile.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
