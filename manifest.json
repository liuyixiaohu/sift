{
  "manifest_version": 3,
  "name": "JobLens",
  "version": "1.0",
  "description": "Smart LinkedIn job filter: flags Reposted, Applied, No Sponsor, Unpaid, and lets you skip companies & title keywords.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
