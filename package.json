{
  "name": "sift",
  "version": "2.10.0",
  "private": true,
  "type": "module",
  "description": "Clean up LinkedIn: filter feed by keywords, hide ads & spam, mute or unfollow inline, and search your rules.",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests build.js eslint.config.js",
    "lint:fix": "eslint --fix src tests build.js eslint.config.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "vitest": "^3.0.0"
  }
}
